# ── Project-specific artifacts ──────────────────────────────
_tooling/                      # Agent tooling & planning artifacts
.pi/                           # Pi agent configuration
frontend/wailsjs/              # Wails auto-generated Go→JS bindings
frontend/dist/                 # Vite frontend build output

# ── Build output ────────────────────────────────────────────
build/bin/
build/*/bin/

# ── Dependencies ────────────────────────────────────────────
node_modules/
vendor/                        # Go vendor (if used)

# ── Secrets & credentials ────────────────────────────────────
.env
.env.*
*.key
*.pem
*.cert
credentials*
secrets*

# ── Go compiled artifacts ────────────────────────────────────
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# ── Temp & logs ──────────────────────────────────────────────
*.log
tmp/
temp/

# ── Editor / OS junk ─────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ── Local overrides ──────────────────────────────────────────
.githooks/
